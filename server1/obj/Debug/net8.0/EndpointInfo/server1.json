  "components": {
    "schemas": {
      "AckRequestDto": {
        "type": "object",
        "properties": {
          "batchToken": {
            "type": "string",
            "nullable": true
          },
          "ackedTrnIDs": {
            "type": "array",
            "items": {
              "type": "number",
              "format": "double"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "LoginRequestDto": {
        "type": "object",
        "properties": {
          "deviceID": {
            "type": "string",
            "nullable": true
          },
          "macAddr": {
            "type": "string",
            "nullable": true
          },
          "ipAddr": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "PollRequestDto": {
        "type": "object",
        "properties": {
          "lastBatchToken": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    }
  }
