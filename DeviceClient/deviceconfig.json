{
  "Devices": [
    {
    "DeviceType": 2,
    "MACAddr": "00:1B:09:00:00:00",
    "IPAddr": "192.168.0.100"
    }
  ],
  "Timing": {
    "PollIntervalSeconds": 8,
    "EventIntervalSeconds": 5,
    "BulkEverySeconds": 10
  },
  "Event": {
    "EventCount": 100,
    "BulkCount": 1000,
    "EnableBulkMode": true
  },
  "Server": {
    "BaseUrl": "http://localhost:5000/api/"
  },
  "Logging": {
    "InfoFile": "logs/device_info.log",
    "DebugFile": "logs/device_debug.log",
    "ErrorFile": "logs/device_error.log",

    "EnableInfo": true,
    "EnableDebug": true,
    "EnableError": true
  }
}